# Copy to .env.pipeline and update paths for your machine.

# Host path for canonical OSM PostGIS data.
OI_OSM_PGDATA_DIR=/Volumes/goose-drive/openinterstate-ingest/docker/osm-pgdata

# Host path for osm2pgsql flatnodes cache.
OI_FLATNODES_DIR=/Volumes/goose-drive/openinterstate-ingest/docker/flatnodes

# Host path for downloaded raw source PBF files.
OI_DOWNLOAD_DIR=/Volumes/goose-drive/openinterstate-ingest/downloads

# Host path for OpenInterstate-generated filtered canonical PBF files.
OI_FILTERED_PBF_DIR=/Volumes/goose-drive/openinterstate-ingest/filtered

# Host path for generated release artifacts and tarballs.
OI_BUILD_DIR=/Volumes/goose-drive/openinterstate-ingest/build

# Host port exposed by docker-compose.yml for the local PostGIS service.
OI_DB_PORT=5434

# Container-network DB URL for Rust jobs run via docker compose.
PRODUCT_DB_URL=postgres://osm:osm_dev@osm-db:5432/osm

# Host-accessible DB coordinates for osm2pgsql and optional psql usage.
OSM_DB_HOST=localhost
OSM_DB_PORT=5434
OSM_DB_NAME=osm
OSM_DB_USER=osm
OSM_DB_PASSWORD=osm_dev

# Default latest U.S. source file.
OI_DEFAULT_US_PBF_URL=https://download.geofabrik.de/north-america/us-latest.osm.pbf

# Canonical import safety:
# - auto: append when canonical tables already exist, create when missing
# - create: only for explicit one-off resets
OSM2PGSQL_MODE=auto
OSM2PGSQL_DROP_MIDDLE=false
OI_ALLOW_CANONICAL_RESET=false
